        P_APPOINTMENTS --> P_APPT_BOOK["/appointments?action=book"]
        P_APPOINTMENTS --> P_APPT_RESCH["/appointments?action=reschedule"]
        P_APPOINTMENTS --> P_APPT_TIMESLOTS["/appointments?action=timeslots"]
        P_QUEUES["/queues"]
