    subgraph STAFF["Staff"]
        S_INDEX["/ (staff)"]
        S_APPOINTMENTS["/staff/appointments"]
        S_APPOINTMENTS --> S_APPT_LIST["/staff/appointments?action=list"]
        S_QUEUES["/staff/queues"]
        S_QUEUES --> S_QUEUES_LIST["/staff/queues?action=list"]
    end

    subgraph ADMIN["Admin"]
        A_INDEX["/ (admin)"]
        A_STAFFLOG["/admin/staffLog"]
        A_USERS["/admin/users"]
        A_REPORTS["/admin/reports"]
