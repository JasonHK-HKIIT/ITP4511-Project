    subgraph SHARED["Shared / Public"]
        LOGIN["/login"]
        REGISTER["/register"]
        LOGOUT["/logout"]
        PROFILE["/profile"]
    end

    ROOT --> PATIENT
    ROOT --> STAFF
    ROOT --> ADMIN
    ROOT --> SHARED
